# Copy this to .env and fill in values. Never commit .env.

# Discord bot — required for polymarket/bot.py
# Create at https://discord.com/developers/applications → Bot → Reset Token
# Channel ID: enable Developer Mode in Discord → right-click channel → Copy ID
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=

# Polymarket trading (optional — only needed for automated order placement)
# Generate at polymarket.com → Settings → API Keys
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_PASSPHRASE=
POLYMARKET_PRIVATE_KEY=

# Riot API (optional — for direct match data if OE has gaps)
RIOT_API_KEY=

# Leaguepedia — keep the user-agent polite (put YOUR contact email here)
LEAGUEPEDIA_USER_AGENT=lol-t2-model/1.0 (contact@example.com)

# Leaguepedia bot password (optional, but strongly recommended for roster_scraper).
# Anonymous Cargo requests have a low rate ceiling and trip "ratelimited" easily.
# Create one at https://lol.fandom.com/wiki/Special:BotPasswords with grants:
#   Basic rights + High API limits + "Create, query and delete data through Cargo".
# Username is shown as  YourFandomName@botlabel ; password is the generated token.
# If left blank, roster_scraper.py runs anonymously (lower rate limit).
LEAGUEPEDIA_USERNAME=
LEAGUEPEDIA_BOT_PASSWORD=

RIOT_API_KEY=